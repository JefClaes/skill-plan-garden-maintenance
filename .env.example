# Copy to .env and fill in. The tests read these.
ANTHROPIC_API_KEY=

# Model that generates the plan from the photos (the "skill" under test).
GENERATION_MODEL=claude-opus-4-8

# Independent model that judges the plan (LLM-as-judge). Kept different from the
# generation model to reduce self-preference bias.
JUDGE_MODEL=claude-sonnet-4-6
